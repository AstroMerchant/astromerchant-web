# --------------------------------------------------
# Application
# --------------------------------------------------
PUBLIC_APP_NAME=AstroMerchant
PUBLIC_APP_URL=http://localhost:4321

# --------------------------------------------------
# API
# --------------------------------------------------
PUBLIC_API_URL=http://localhost:3000

# --------------------------------------------------
# Stellar Network
# --------------------------------------------------
PUBLIC_STELLAR_NETWORK=TESTNET
PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --------------------------------------------------
# Asset Configuration
# --------------------------------------------------
PUBLIC_ASSET_CODE=USDC
PUBLIC_ASSET_ISSUER=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------------
# Wallet
# --------------------------------------------------
PUBLIC_ENABLE_FREIGHTER=true
PUBLIC_ENABLE_XBULL=true

# --------------------------------------------------
# Analytics (Optional)
# --------------------------------------------------
PUBLIC_ANALYTICS_ID=

# --------------------------------------------------
# Feature Flags
# --------------------------------------------------
PUBLIC_ENABLE_DARK_MODE=true
PUBLIC_ENABLE_CHECKOUT=true
PUBLIC_ENABLE_STELLAR_PAYMENTS=true
